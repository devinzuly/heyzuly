<section id="join" class="cta">
  <div class="wrap">
    <div class="band2">
      <h2>Be first to meet <em>Zuly</em>.</h2>
      <p>We're opening early access soon. Leave your email and we'll bring you in — gently, one step at a time.</p>
      <form class="join" id="joinForm" novalidate>
        <input
          type="email"
          id="email"
          placeholder="you@email.com"
          aria-label="Email address"
          autocomplete="email"
          required
        />
        <button class="btn btn-gold" type="submit">Join the waitlist</button>
      </form>
      <p class="thanks" id="thanks" role="status" aria-live="polite"></p>
      <p class="join-note">
        Monthly membership at launch · no spam, just a hello when it's time.<br />
        <span style="color:var(--gold-soft);font-weight:700;">App coming soon — log in when we open.</span>
      </p>
    </div>
  </div>
</section>

<script>
  (function () {
    var f = document.getElementById('joinForm');
    var t = document.getElementById('thanks');
    var e = document.getElementById('email');
    if (!f) return;
    f.addEventListener('submit', function (ev) {
      ev.preventDefault();
      var v = (e && e.value ? e.value : '').trim();
      if (!v || v.indexOf('@') < 1) {
        if (t) t.textContent = 'A real email — try again 🙂';
        return;
      }
      f.style.display = 'none';
      if (t) t.textContent = "You're in. We'll be in touch soon. ✦";
    });
  })();
</script>
