---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import IdeaBand from '../components/IdeaBand.astro';
import Pillars from '../components/Pillars.astro';
import HowItWorks from '../components/HowItWorks.astro';
import MeetZulyChat from '../components/MeetZulyChat.astro';
import Channels from '../components/Channels.astro';
import Program from '../components/Program.astro';
import Trust from '../components/Trust.astro';
import WhyZuly from '../components/WhyZuly.astro';
import Waitlist from '../components/Waitlist.astro';
---

<BaseLayout>
  <Header />
  <main id="top">
    <Hero />
    <IdeaBand />
    <Pillars />
    <HowItWorks />
    <MeetZulyChat />
    <Channels />
    <Program />
    <Trust />
    <WhyZuly />
    <Waitlist />
  </main>
  <Footer />
</BaseLayout>
