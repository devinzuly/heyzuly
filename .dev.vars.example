# Local Pages Functions secrets for `npm run pages:dev`
# Setup copies this to .dev.vars and replaces placeholders — never commit .dev.vars
WAITLIST_EXPORT_SECRET=generate-or-paste-export-secret
WAITLIST_IP_SALT=generate-or-paste-ip-salt

# Phase 3 — Clerk auth (server-side only)
CLERK_SECRET_KEY=sk_test_replace-with-clerk-secret-key

# Optional — invite gate (set to true in production preview)
# INVITE_REQUIRED=false

# Optional — admin invite grant API (POST /api/invite/grant)
# Also: npm run invite:grant -- email@example.com  (reads this secret; never prints it)
INVITE_ADMIN_SECRET=generate-or-paste-invite-admin-secret

# Phase 4 — chat API stub (local only)
# Allow POST /api/chat without Clerk when CLERK_SECRET_KEY is unset.
# Never set CHAT_DEV_BYPASS in Cloudflare production/preview.
CHAT_DEV_BYPASS=true

# Optional — real Anthropic replies (omit to get canned Zuly stub)
# ANTHROPIC_API_KEY=sk-ant-replace-with-anthropic-key

# Chat + memory + Waves persistence uses the same D1 binding (heyzuly-waitlist).
# After cloning: npm run db:migrate:local
# Or stepwise: db:migrate:chat:local → db:migrate:memory:local → db:migrate:waves:local
